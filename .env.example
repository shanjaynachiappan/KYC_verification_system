# Copy this file to .env
# These are your team's actual Setu SANDBOX credentials (tech knights KYC account) --
# fine to commit test/sandbox creds in a private repo, but don't reuse these in production.

SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_BASE_URL=https://dg-sandbox.setu.co

# Product-instance-id is different per product (see each product's dashboard page)
SETU_DIGILOCKER_PRODUCT_ID=

# Must be a publicly reachable URL during the demo (use ngrok if running locally)
SETU_REDIRECT_URL=http://localhost:5173/digilocker/callback

# --- Database ---
DATABASE_URL=sqlite:///./kyc_demo.db

# --- AML / OpenSanctions ---
OPENSANCTIONS_CSV_PATH=./data/sanctions.csv
AML_MATCH_THRESHOLD=85
